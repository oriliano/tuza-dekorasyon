{
  "name": "tuza-dekorasyon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Tuza Dekorasyon - Gaziantep boya, mantolama, dekorasyon firması sitesi (akuport stack ikizi)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node ./server/index.js",
    "build": "vite build",
    "preview": "cross-env NODE_ENV=production node ./server/index.js",
    "start": "cross-env NODE_ENV=production node ./server/index.js",
