# PostgreSQL bağlantı adresi (Railway/Neon vb. "Connection URL")
# Boş bırakılırsa uygulama seed verisiyle (DB'siz) çalışır.
DATABASE_URL=

# Sunucu portu (lokal için 3000)
PORT=3000

# Yönetim paneli (/panel) şifresi. Production'da zorunludur.
ADMIN_PASSWORD=degistirilecek-guclu-sifre

# Cookie imzası için ayrı gizli değer. Boş bırakılırsa ADMIN_PASSWORD kullanılır.
ADMIN_SESSION_SECRET=degistirilecek-uzun-rastgele-deger

# Görsel yükleme klasörü (kalıcı disk bağlarsan /data/uploads yap).
UPLOAD_DIR=
UPLOAD_PUBLIC_PATH=/uploads
UPLOAD_MAX_BYTES=5242880

# Site kök adresi (sitemap.xml ve canonical/OG için).
SITE_URL=https://tuzadekorasyon.com
